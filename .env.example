# ========================================
# CONFIGURATION ENVIRONNEMENT - TEMPLATE
# ========================================
# Copier ce fichier en `.env` et remplir les valeurs

# ============ OPENAI API ============
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modèle recommandé : gpt-4o-mini (économique) ou gpt-4o (plus puissant)
OPENAI_MODEL=gpt-4o-mini

# ============ GOOGLE SHEETS API ============
# Chemin vers le fichier JSON des credentials service account
GOOGLE_CREDENTIALS_PATH=config/google_credentials.json
# Obtenir credentials : https://console.cloud.google.com/

# ============ WEBHOOK SECURITY ============
# Secret pour vérifier signatures webhooks (générer aléatoirement)
WEBHOOK_SECRET=votre_secret_webhook_aleatoire_ici
# Exemple génération : python -c "import secrets; print(secrets.token_hex(32))"

# ============ ADMIN API ============
# Clé admin pour endpoints sensibles (/api/admin/*)
ADMIN_API_KEY=admin_votre_cle_secrete_ici

# ============ TWILIO (WhatsApp/SMS) ============
# Si utilisation Twilio pour WhatsApp Business API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Docs : https://www.twilio.com/docs/whatsapp

# ============ REDIS (CACHE) ============
# Optionnel : pour cache mémoire conversations
REDIS_URL=redis://localhost:6379
# Si non fourni, utilise mémoire locale (moins performant multi-instances)

# ============ LOGGING ============
LOG_LEVEL=INFO
# Options : DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============ DEPLOYMENT ============
ENVIRONMENT=development
# Options : development, staging, production

# ============ CONFIGURATION ARTISANS ============
# Chemin vers fichier config artisans (JSON)
ARTISAN_CONFIG_PATH=config/artisans.json
